{
  "keymap": "macos",
  "editor": {
    "keyboard_disambiguate_escape_codes": true,
    "keyboard_report_alternate_keys": true
  },
  "keybindings": [
    {
      "key": "f",
      "modifiers": [
        "alt"
      ],
      "action": "move_word_right",
      "when": "global"
    },
    {
      "key": "b",
      "modifiers": [
        "alt"
      ],
      "action": "move_word_left",
      "when": "global"
    },
    {
      "key": "b",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "normal"
    },
    {
      "key": "b",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "normal"
    },
    {
      "key": "e",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "file_explorer"
    },
    {
      "key": "]",
      "modifiers": [
        "alt"
      ],
      "action": "noop",
      "when": "file_explorer"
    },
    {
      "key": "b",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "file_explorer"
    },
    {
      "key": "e",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "normal"
    },
    {
      "key": "j",
      "modifiers": [
        "alt"
      ],
      "action": "focus_editor",
      "when": "global"
    },
    {
      "key": "e",
      "modifiers": [
        "ctrl"
      ],
      "action": "noop",
      "when": "normal"
    },
    {
      "key": "j",
      "modifiers": [
        "ctrl",
        "alt"
      ],
      "action": "focus_file_explorer",
      "when": "global"
    }
  ],
  "theme": "light",
  "active_keybinding_map": "macos",
  "file_explorer": {
    "show_hidden": true
  }
}
