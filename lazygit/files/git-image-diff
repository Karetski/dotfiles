#!/bin/sh
# Git external diff script for lazygit
# Args: path old-file old-hex old-mode new-file new-hex new-mode
path="$1"
old_file="$2"
new_file="$5"

render_image() {
  local file="$1"
  local cache_key
  cache_key=$(md5 -q "$file" 2>/dev/null || echo "0")
  local cache_file="/tmp/gid-${cache_key}.cache"

  if [ -s "$cache_file" ]; then
    cat "$cache_file"
  else
    rm -f "$cache_file"
    TERM=xterm-256color chafa --format=symbols --animate=off --colors=256 "$file" | \
      perl -pe 's/\x1b\[[0-9;?]*[a-ln-zA-Z]//g' | tee "$cache_file"
    [ -s "$cache_file" ] || rm -f "$cache_file"
  fi
}

case "$new_file" in
  *.png|*.jpg|*.jpeg|*.gif|*.webp|*.bmp|*.tiff|*.ico|*.svg)
    if [ -f "$new_file" ]; then
      render_image "$new_file"
    else
      echo "(deleted)"
    fi
    ;;
  *)
    diff -u --label "a/$path" --label "b/$path" "$old_file" "$new_file" 2>/dev/null || true
    ;;
esac
