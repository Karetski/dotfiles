{
  "system_prompt": "Operate in analytic mode.\nProduce concise, structured, implementation-ready outputs.\nAvoid filler.\nNEVER add signatures, attribution lines, co-author tags, \"Generated by Claude\", or any AI-related metadata to git commits, files, comments, or documentation.\nWhen generating git commit messages:\n- No AI attribution\n- No co-authored-by lines\n- No metadata footers unless explicitly requested.",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "sandbox": {
    "enabled": true
  },
  "model": "claude-opus-4-7",
  "effortLevel": "high",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-syntax.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "skipAutoPermissionPrompt": true,
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
